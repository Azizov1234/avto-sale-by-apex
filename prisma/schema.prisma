generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////
// ENUMS 
//////////////////////
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////
// ENUMS
//////////////////////

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  SALES
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
}

enum DealStatus {
  OPEN
  WON
  LOST
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

//////////////////////
// MODELS
//////////////////////

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SALES)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads      Lead[]
  tasks      Task[]
  activities Activity[]
  notes      Note[]
  payments   Payment[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  company   String?
  address   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads    Lead[]
  deals    Deal[]
  payments Payment[]
  invoices Invoice[]
}

model Lead {
  id           String     @id @default(cuid())
  title        String
  status       LeadStatus @default(NEW)
  source       String?
  value        Float      @default(0)
  customerId   String?
  assignedToId String?
  isDeleted    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  customer   Customer? @relation(fields: [customerId], references: [id])
  assignedTo User?     @relation(fields: [assignedToId], references: [id])
  notes      Note[]
}

model Deal {
  id         String     @id @default(cuid())
  title      String
  value      Float
  status     DealStatus @default(OPEN)
  stage      String     @default("Qualification")
  customerId String
  isDeleted  Boolean    @default(false)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  customer Customer  @relation(fields: [customerId], references: [id])
  notes    Note[]
  payments Payment[]
}

model Task {
  id        String     @id @default(cuid())
  title     String
  status    TaskStatus @default(TODO)
  dueDate   DateTime?
  userId    String
  createdAt DateTime   @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Note {
  id        String   @id @default(cuid())
  content   String
  userId    String
  leadId    String?
  dealId    String?
  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  lead Lead? @relation(fields: [leadId], references: [id])
  deal Deal? @relation(fields: [dealId], references: [id])
}

model Activity {
  id        String   @id @default(cuid())
  action    String
  metadata  Json?
  userId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

//////////////////////
// MONEY
//////////////////////

model Payment {
  id         String        @id @default(cuid())
  amount     Float
  status     PaymentStatus @default(PAID)
  method     PaymentMethod @default(CASH)
  customerId String
  dealId     String?
  userId     String?
  createdAt  DateTime      @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
  deal     Deal?    @relation(fields: [dealId], references: [id])
  user     User?    @relation(fields: [userId], references: [id])
}

model Invoice {
  id         String    @id @default(cuid())
  number     String    @unique
  amount     Float
  status     String    @default("DRAFT") // DRAFT, PAID
  customerId String
  dueDate    DateTime?
  createdAt  DateTime  @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

//////////////////////
// LMS (LIGHT)
//////////////////////
enum UserRole {
  USER
  ADMIN
  SUPERADMIN
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DELIVERED
  CANCELLED
}

enum Status {
  active
  deleted
  blocked
}

enum CarCondition {
  NEW // salondan chiqqan
  USED // ishlatilgan
  CERTIFIED // sertifikatlangan ishlatilgan mashina
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum EngineType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
}

enum PlanMonths {
  ONE
  THREE
  SIX
  NINE
  TWELVE
  TWENTY_FOUR
}

enum OrderType {
  FULL_PAYMENT
  INSTALLMENT
  TRADE_IN
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  REFUNDED
}

//////////////////////
// USER
//////////////////////

model User {
  id           Int      @id @default(autoincrement())
  name         String
  phone        String   @unique
  avatarUrl    String?
  email        String   @unique
  status       Status?  @default(active)
  password     String
  role         UserRole @default(USER)
  refreshToken String?

  orders    Order[]
  reviews   Review[]
  adminLogs AdminActionLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// CAR CATEGORY
//////////////////////

model CarCategory {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  status    Status?  @default(active)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cars      Car[]
}

//////////////////////
// CAR
//////////////////////

model Car {
  id     Int     @id @default(autoincrement())
  title  String  @unique
  status Status? @default(active)

  brand          String
  price          Float
  year           Int
  mileage        Int
  carConditation CarCondition
  description    String
  engine         EngineType
  transmission   Transmission
  imageUrl       String?

  categoryId Int?
  category   CarCategory? @relation(fields: [categoryId], references: [id])

  installmentPlans InstallmentPlan[]
  orders           Order[]
  reviews          Review[]
  campaigns        DiscountCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////
// INSTALLMENT PLAN
//////////////////////

model InstallmentPlan {
  id     Int     @id @default(autoincrement())
  status Status? @default(active)

  carId    Int
  months   PlanMonths
  discount Float
  interest Float

  car Car @relation(fields: [carId], references: [id])

  orders Order[]

  @@unique([carId, months])
}

//////////////////////
// ORDER
//////////////////////

model Order {
  id Int @id @default(autoincrement())

  userId Int
  carId  Int
  planId Int?

  orderType OrderType

  basePrice   Float
  discount    Float       @default(0)
  interest    Float       @default(0)
  totalPrice  Float
  status      Status      @default(active)
  orderStatus OrderStatus @default(PENDING)
  monthlyPay  Float?

  paymentStatus PaymentStatus @default(PENDING)

  user User             @relation(fields: [userId], references: [id])
  car  Car              @relation(fields: [carId], references: [id])
  plan InstallmentPlan? @relation(fields: [planId], references: [id])

  payments PaymentHistory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([carId])
  @@index([paymentStatus])
  @@index([orderStatus])
}

//////////////////////
// PAYMENT HISTORY
//////////////////////

model PaymentHistory {
  id     Int     @id @default(autoincrement())
  status Status? @default(active)

  orderId Int
  amount  Float
  paidAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

//////////////////////
// REVIEW
//////////////////////

model Review {
  id     Int     @id @default(autoincrement())
  status Status? @default(active)

  userId Int
  carId  Int

  rating  Int
  comment String?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  car  Car  @relation(fields: [carId], references: [id])
}

//////////////////////
// STATS CACHE
//////////////////////

model StatsCache {
  id Int @id @default(autoincrement())

  key            String   @unique
  data           Json
  lastCalculated DateTime @default(now())
  createdAt      DateTime @default(now())
}

model AdminActionLog {
  id     Int     @id @default(autoincrement())
  status Status? @default(active)

  adminId   Int
  action    String
  entity    String
  entityId  Int
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id])
}

//////////////////////
// DISCOUNT CAMPAIGN
//////////////////////

model DiscountCampaign {
  id     Int     @id @default(autoincrement())
  status Status? @default(active)

  name        String
  description String?
  discount    Float
  startDate   DateTime
  endDate     DateTime

  cars Car[]
}
